<?php
/**
 * Database Connection
 */
function db_connect() {
    static $conn;
    
    if (!isset($conn)) {
        // Load configuration
        $config = require_once __DIR__ . '/config.php';
        
        // Create connection
        $conn = new mysqli(
            $config['db_host'],
            $config['db_user'],
            $config['db_pass'],
            $config['db_name']
        );
        
        // Check connection
        if ($conn->connect_error) {
            die("فشل الاتصال بقاعدة البيانات: " . $conn->connect_error);
        }
        
        // Set charset to utf8mb4
        $conn->set_charset("utf8mb4");

        $col = $conn->query("SHOW COLUMNS FROM users LIKE 'city'");
        if ($col && $col->num_rows === 0) {
            $conn->query("ALTER TABLE users ADD COLUMN city varchar(100) DEFAULT NULL");
        }

        $col = $conn->query("SHOW COLUMNS FROM users LIKE 'address'");
        if ($col && $col->num_rows === 0) {
            $conn->query("ALTER TABLE users ADD COLUMN address varchar(255) DEFAULT NULL");
        }
    }
    
    return $conn;
}

/**
 * Sanitize output
 */
if (!function_exists('e')) {
    function e($string) {
        return htmlspecialchars($string, ENT_QUOTES, 'UTF-8');
    }
}

/**
 * Redirect to another page
 */
if (!function_exists('redirect')) {
    function redirect($url) {
        header("Location: $url");
        exit();
    }
}

/**
 * Check if user is logged in
 */
if (!function_exists('is_logged_in')) {
    function is_logged_in() {
        return isset($_SESSION['user_id']);
    }
}

/**
 * Require user to be logged in
 */
if (!function_exists('require_login')) {
    function require_login() {
        if (!is_logged_in()) {
            $_SESSION['redirect_url'] = $_SERVER['REQUEST_URI'];
            redirect('login.php');
        }
    }
}
?>
